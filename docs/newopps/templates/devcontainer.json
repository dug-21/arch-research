{
  "name": "Agentic Development - 5-Phase Workflow",
  "dockerComposeFile": "docker-compose.yml",
  "service": "agentic-dev",
  "workspaceFolder": "/workspace",

  // Features to install
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },

  // VS Code customizations
  "customizations": {
    "vscode": {
      "extensions": [
        // Essential
        "anthropic.claude-code",

        // Git & GitHub
        "github.vscode-pull-request-github",
        "eamodio.gitlens",

        // Testing
        "orta.vscode-jest",
        "hbenl.vscode-test-explorer",

        // Code Quality
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",

        // Documentation
        "yzhang.markdown-all-in-one",
        "bierner.markdown-mermaid",

        // Docker
        "ms-azuretools.vscode-docker"
      ],

      "settings": {
        // Claude Code MCP Configuration
        "claude.mcpServers": {
          "claude-flow": {
            "command": "npx",
            "args": ["claude-flow@alpha", "mcp", "start"],
            "description": "Claude-Flow orchestration (87 MCP tools)"
          },
          "goalie": {
            "command": "npx",
            "args": ["goalie", "mcp", "start"],
            "description": "Goalie GOAP search for research"
          },
          "agentdb": {
            "command": "npx",
            "args": ["agentdb", "mcp", "start"],
            "description": "AgentDB vector database (20 tools)"
          }
        },

        // Terminal Configuration
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "AGENTIC_WORKFLOW_ENABLED": "true",
          "PHASE_SCRIPTS_PATH": "/workspace/.agentic/scripts"
        },

        // Testing Configuration
        "jest.jestCommandLine": "npm test --",
        "jest.autoRun": "off",

        // Editor Configuration
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": true
        },

        // File Associations
        "files.associations": {
          "*.sparc.md": "markdown",
          "acceptance-criteria.json": "jsonc"
        }
      }
    }
  },

  // Container environment variables
  "containerEnv": {
    // Workflow Configuration
    "AGENTIC_WORKFLOW_VERSION": "5-phase-v1.0",
    "WORKSPACE_ROOT": "/workspace",

    // AgentDB Configuration (in-process)
    "AGENTDB_ENABLED": "true",
    "AGENTDB_PATH": "/data/agentdb.db",
    "AGENTDB_VECTOR_SEARCH_ENABLED": "true",

    // HiveMind Configuration
    "HIVEMIND_ENABLED": "true",
    "ENABLE_QUEEN_COORDINATOR": "true",
    "ENABLE_COLLECTIVE_INTELLIGENCE": "true",
    "ENABLE_MEMORY_MANAGER": "true",
    "ENABLE_WORKER_SPECIALISTS": "true",
    "ENABLE_SCOUT_EXPLORERS": "true",

    // Phase Configuration
    "ENABLE_PHASE_1_RESEARCH": "true",
    "ENABLE_PHASE_2_FORMALIZE": "true",
    "ENABLE_PHASE_3_SPARC": "true",
    "ENABLE_PHASE_4_APPROVAL": "true",
    "ENABLE_PHASE_5_TDD": "true",

    // TDD Configuration (London School)
    "TDD_STYLE": "london",
    "TDD_MOCK_DEPENDENCIES": "true",
    "TDD_TEST_COVERAGE_THRESHOLD": "80",

    // Truth Verification Configuration
    "ENABLE_TRUTH_VERIFICATION": "true",
    "TRUTH_VERIFICATION_THRESHOLD": "0.95",
    "TRUTH_AUTO_ROLLBACK": "true",

    // Swarm Configuration
    "MAX_PARALLEL_WORKERS": "10",
    "WORKER_STATUS_INTERVAL_MS": "30000",
    "SWARM_MEMORY_SYNC_ENABLED": "true",

    // Pattern-Driven (Optional Optimization)
    "ENABLE_PATTERN_MATCHING": "true",
    "PATTERN_MATCH_THRESHOLD": "0.85",
    "PATTERN_REUSE_ENABLED": "true",

    // MCP Configuration
    "MCP_SERVER_PORT": "3000",
    "ENABLE_CLAUDE_FLOW_MCP": "true",
    "ENABLE_GOALIE_MCP": "true",
    "ENABLE_AGENTDB_MCP": "true"
  },

  // Mounts for persistent data
  "mounts": [
    // AgentDB persistent storage
    "source=agentic-dev-agentdb,target=/data,type=volume",

    // GitHub CLI config (persistent auth)
    "source=agentic-dev-gh-config,target=/root/.config/gh,type=volume",

    // Agent definitions (read-only from host)
    "source=${localWorkspaceFolder}/.agentic/agents,target=/app/agents,type=bind,readonly",

    // Proven patterns library (if exists)
    "source=${localWorkspaceFolder}/.agentic/patterns,target=/patterns,type=bind,consistency=cached"
  ],

  // Ports to forward
  "forwardPorts": [
    3000,  // MCP Server
    3001,  // AgentDB Monitoring API
    8080   // Optional: Swagger UI for API docs preview
  ],

  // Port attributes
  "portsAttributes": {
    "3000": {
      "label": "MCP Server",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "AgentDB Monitoring",
      "onAutoForward": "silent"
    },
    "8080": {
      "label": "Swagger UI Preview",
      "onAutoForward": "silent"
    }
  },

  // Post-create command (runs once after container creation)
  "postCreateCommand": "bash /workspace/.agentic/scripts/setup.sh",

  // Post-start command (runs every time container starts)
  "postStartCommand": "bash /workspace/.agentic/scripts/start.sh",

  // User to run as
  "remoteUser": "root",

  // Lifecycle scripts
  "initializeCommand": "echo 'Initializing Agentic Development Environment...'",
  "onCreateCommand": "echo 'Installing dependencies...' && npm install",

  // Wait for services to be ready
  "waitFor": "postStartCommand",

  // Update remote user UID/GID to match host (for file permissions)
  "updateRemoteUserUID": true,

  // Shutdown action
  "shutdownAction": "stopCompose"
}
