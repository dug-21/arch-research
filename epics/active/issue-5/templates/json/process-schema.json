{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Business Process Inventory Schema",
  "description": "Comprehensive schema for documenting business processes with all attributes and relationships",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Inventory metadata and versioning information",
      "properties": {
        "inventoryId": {
          "type": "string",
          "description": "Unique identifier for this process inventory"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Version number following semantic versioning"
        },
        "createdDate": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when inventory was created"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last update"
        },
        "organization": {
          "type": "string",
          "description": "Organization or business unit name"
        },
        "scope": {
          "type": "string",
          "enum": ["enterprise", "department", "team", "project"],
          "description": "Scope of the process inventory"
        },
        "methodology": {
          "type": "string",
          "description": "Methodology used for process documentation"
        },
        "totalProcessCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of processes in this inventory"
        }
      },
      "required": ["inventoryId", "version", "createdDate", "organization", "scope"]
    },
    "processes": {
      "type": "array",
      "description": "Array of business processes",
      "items": {
        "$ref": "#/definitions/process"
      }
    },
    "categories": {
      "type": "array",
      "description": "Process category definitions",
      "items": {
        "$ref": "#/definitions/category"
      }
    },
    "stakeholders": {
      "type": "array",
      "description": "Stakeholder directory",
      "items": {
        "$ref": "#/definitions/stakeholder"
      }
    },
    "systems": {
      "type": "array",
      "description": "IT systems inventory",
      "items": {
        "$ref": "#/definitions/system"
      }
    },
    "validationRules": {
      "type": "object",
      "description": "Business rules and validation criteria",
      "$ref": "#/definitions/validationRules"
    }
  },
  "required": ["metadata", "processes"],
  "definitions": {
    "process": {
      "type": "object",
      "description": "Individual business process definition",
      "properties": {
        "processId": {
          "type": "string",
          "pattern": "^[A-Z]{2,5}-\\d{3,6}$",
          "description": "Unique process identifier (e.g., PROC-001, PAY-12345)"
        },
        "processName": {
          "type": "string",
          "minLength": 5,
          "maxLength": 100,
          "description": "Clear, descriptive process name"
        },
        "description": {
          "type": "string",
          "maxLength": 1000,
          "description": "Detailed process description and purpose"
        },
        "category": {
          "type": "string",
          "description": "Primary process category"
        },
        "subCategory": {
          "type": "string",
          "description": "Secondary classification"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$",
          "description": "Process version number"
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "planned", "suspended", "retired"],
          "description": "Current process status"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "owner": {
          "$ref": "#/definitions/processOwner"
        },
        "operationalDetails": {
          "$ref": "#/definitions/operationalDetails"
        },
        "technicalDetails": {
          "$ref": "#/definitions/technicalDetails"
        },
        "businessContext": {
          "$ref": "#/definitions/businessContext"
        },
        "qualityMetrics": {
          "$ref": "#/definitions/qualityMetrics"
        },
        "riskAssessment": {
          "$ref": "#/definitions/riskAssessment"
        },
        "improvementOpportunities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/improvement"
          }
        },
        "relationships": {
          "$ref": "#/definitions/processRelationships"
        }
      },
      "required": ["processId", "processName", "description", "category", "status", "owner"]
    },
    "processOwner": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Process owner full name"
        },
        "title": {
          "type": "string",
          "description": "Job title or role"
        },
        "department": {
          "type": "string",
          "description": "Department or business unit"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Contact email address"
        },
        "stakeholderId": {
          "type": "string",
          "description": "Reference to stakeholder record"
        }
      },
      "required": ["name", "department"]
    },
    "operationalDetails": {
      "type": "object",
      "properties": {
        "frequency": {
          "type": "string",
          "enum": ["continuous", "real-time", "hourly", "daily", "weekly", "monthly", "quarterly", "annually", "ad-hoc", "event-driven"],
          "description": "How often the process executes"
        },
        "duration": {
          "type": "object",
          "properties": {
            "average": {
              "type": "integer",
              "minimum": 0,
              "description": "Average duration in minutes"
            },
            "minimum": {
              "type": "integer",
              "minimum": 0,
              "description": "Minimum duration in minutes"
            },
            "maximum": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum duration in minutes"
            }
          }
        },
        "volume": {
          "type": "object",
          "properties": {
            "average": {
              "type": "integer",
              "minimum": 0,
              "description": "Average volume per period"
            },
            "peak": {
              "type": "integer",
              "minimum": 0,
              "description": "Peak volume per period"
            },
            "unit": {
              "type": "string",
              "enum": ["transactions", "requests", "items", "cases", "documents"],
              "description": "Volume measurement unit"
            },
            "period": {
              "type": "string",
              "enum": ["hour", "day", "week", "month"],
              "description": "Volume measurement period"
            }
          }
        },
        "slaRequirements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "metric": {
                "type": "string",
                "description": "SLA metric name"
              },
              "target": {
                "type": "string",
                "description": "Target value or threshold"
              },
              "measurement": {
                "type": "string",
                "description": "How the metric is measured"
              }
            }
          }
        },
        "businessPriority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Business priority level"
        },
        "seasonalVariation": {
          "type": "boolean",
          "description": "Whether process has seasonal variations"
        },
        "geographicScope": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Geographic regions where process operates"
        }
      }
    },
    "technicalDetails": {
      "type": "object",
      "properties": {
        "automationLevel": {
          "type": "string",
          "enum": ["manual", "semi-automated", "fully-automated", "ai-enhanced"],
          "description": "Level of process automation"
        },
        "systemsInvolved": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "systemId": {
                "type": "string",
                "description": "System identifier"
              },
              "systemName": {
                "type": "string",
                "description": "System name"
              },
              "role": {
                "type": "string",
                "enum": ["primary", "secondary", "integration", "reporting"],
                "description": "System role in process"
              },
              "criticality": {
                "type": "string",
                "enum": ["critical", "important", "supporting"],
                "description": "System criticality to process"
              }
            }
          }
        },
        "dataFlow": {
          "type": "object",
          "properties": {
            "inputs": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/dataSource"
              }
            },
            "outputs": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/dataOutput"
              }
            }
          }
        },
        "integrationPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["api", "file", "database", "message-queue", "webhook", "batch"],
                "description": "Integration type"
              },
              "system": {
                "type": "string",
                "description": "Connected system"
              },
              "direction": {
                "type": "string",
                "enum": ["inbound", "outbound", "bidirectional"],
                "description": "Data flow direction"
              },
              "frequency": {
                "type": "string",
                "description": "Integration frequency"
              }
            }
          }
        },
        "securityRequirements": {
          "type": "object",
          "properties": {
            "classification": {
              "type": "string",
              "enum": ["public", "internal", "confidential", "restricted", "top-secret"],
              "description": "Data classification level"
            },
            "accessControls": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Access control requirements"
            },
            "complianceRequirements": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Regulatory compliance requirements"
            }
          }
        }
      }
    },
    "businessContext": {
      "type": "object",
      "properties": {
        "businessRules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ruleId": {
                "type": "string",
                "description": "Business rule identifier"
              },
              "description": {
                "type": "string",
                "description": "Rule description"
              },
              "condition": {
                "type": "string",
                "description": "Rule condition"
              },
              "action": {
                "type": "string",
                "description": "Action when condition is met"
              },
              "exceptions": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Rule exceptions"
              }
            }
          }
        },
        "stakeholders": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/processStakeholder"
          }
        },
        "customerImpact": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "none"],
          "description": "Impact on external customers"
        },
        "revenueImpact": {
          "type": "string",
          "enum": ["direct", "indirect", "cost-center", "none"],
          "description": "Impact on revenue generation"
        }
      }
    },
    "qualityMetrics": {
      "type": "object",
      "properties": {
        "successRate": {
          "type": "object",
          "properties": {
            "current": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Current success rate percentage"
            },
            "target": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Target success rate percentage"
            },
            "trend": {
              "type": "string",
              "enum": ["improving", "stable", "declining"],
              "description": "Performance trend"
            }
          }
        },
        "keyPerformanceIndicators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "KPI name"
              },
              "measurement": {
                "type": "string",
                "description": "How KPI is measured"
              },
              "currentValue": {
                "type": "string",
                "description": "Current KPI value"
              },
              "targetValue": {
                "type": "string",
                "description": "Target KPI value"
              },
              "frequency": {
                "type": "string",
                "description": "Measurement frequency"
              }
            }
          }
        },
        "qualityGates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "gate": {
                "type": "string",
                "description": "Quality gate name"
              },
              "criteria": {
                "type": "string",
                "description": "Gate criteria"
              },
              "owner": {
                "type": "string",
                "description": "Gate owner"
              }
            }
          }
        }
      }
    },
    "riskAssessment": {
      "type": "object",
      "properties": {
        "riskLevel": {
          "type": "string",
          "enum": ["very-low", "low", "medium", "high", "very-high"],
          "description": "Overall process risk level"
        },
        "riskFactors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "factor": {
                "type": "string",
                "description": "Risk factor name"
              },
              "description": {
                "type": "string",
                "description": "Risk description"
              },
              "probability": {
                "type": "string",
                "enum": ["very-low", "low", "medium", "high", "very-high"],
                "description": "Probability of risk occurrence"
              },
              "impact": {
                "type": "string",
                "enum": ["very-low", "low", "medium", "high", "very-high"],
                "description": "Impact if risk occurs"
              },
              "mitigation": {
                "type": "string",
                "description": "Risk mitigation strategy"
              }
            }
          }
        },
        "singlePointsOfFailure": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Critical dependencies that could cause failure"
        }
      }
    },
    "improvement": {
      "type": "object",
      "properties": {
        "opportunityId": {
          "type": "string",
          "description": "Improvement opportunity identifier"
        },
        "title": {
          "type": "string",
          "description": "Improvement title"
        },
        "description": {
          "type": "string",
          "description": "Detailed improvement description"
        },
        "type": {
          "type": "string",
          "enum": ["automation", "optimization", "integration", "elimination", "standardization"],
          "description": "Type of improvement"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Improvement priority"
        },
        "estimatedEffort": {
          "type": "string",
          "description": "Estimated implementation effort"
        },
        "expectedBenefits": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Expected benefits from improvement"
        },
        "status": {
          "type": "string",
          "enum": ["identified", "planned", "in-progress", "completed", "cancelled"],
          "description": "Improvement status"
        }
      }
    },
    "processRelationships": {
      "type": "object",
      "properties": {
        "upstreamProcesses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "processId": {
                "type": "string",
                "description": "Upstream process ID"
              },
              "relationship": {
                "type": "string",
                "enum": ["triggers", "provides-input", "prerequisite"],
                "description": "Type of upstream relationship"
              },
              "criticality": {
                "type": "string",
                "enum": ["critical", "important", "optional"],
                "description": "Relationship criticality"
              }
            }
          }
        },
        "downstreamProcesses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "processId": {
                "type": "string",
                "description": "Downstream process ID"
              },
              "relationship": {
                "type": "string",
                "enum": ["triggered-by", "receives-input", "depends-on"],
                "description": "Type of downstream relationship"
              },
              "criticality": {
                "type": "string",
                "enum": ["critical", "important", "optional"],
                "description": "Relationship criticality"
              }
            }
          }
        },
        "subProcesses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Sub-process IDs"
        },
        "parentProcess": {
          "type": "string",
          "description": "Parent process ID if this is a sub-process"
        }
      }
    },
    "category": {
      "type": "object",
      "properties": {
        "categoryId": {
          "type": "string",
          "description": "Category identifier"
        },
        "name": {
          "type": "string",
          "description": "Category name"
        },
        "description": {
          "type": "string",
          "description": "Category description"
        },
        "parentCategory": {
          "type": "string",
          "description": "Parent category ID"
        }
      }
    },
    "stakeholder": {
      "type": "object",
      "properties": {
        "stakeholderId": {
          "type": "string",
          "description": "Stakeholder identifier"
        },
        "name": {
          "type": "string",
          "description": "Stakeholder name"
        },
        "title": {
          "type": "string",
          "description": "Job title"
        },
        "department": {
          "type": "string",
          "description": "Department"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["owner", "participant", "approver", "reviewer", "observer"],
          "description": "Primary role type"
        }
      }
    },
    "system": {
      "type": "object",
      "properties": {
        "systemId": {
          "type": "string",
          "description": "System identifier"
        },
        "name": {
          "type": "string",
          "description": "System name"
        },
        "description": {
          "type": "string",
          "description": "System description"
        },
        "type": {
          "type": "string",
          "enum": ["core", "supporting", "integration", "reporting", "external"],
          "description": "System type"
        },
        "vendor": {
          "type": "string",
          "description": "System vendor"
        },
        "status": {
          "type": "string",
          "enum": ["production", "development", "deprecated", "retired"],
          "description": "System status"
        }
      }
    },
    "processStakeholder": {
      "type": "object",
      "properties": {
        "stakeholderId": {
          "type": "string",
          "description": "Reference to stakeholder"
        },
        "role": {
          "type": "string",
          "enum": ["owner", "participant", "approver", "reviewer", "informed"],
          "description": "Role in this process"
        },
        "responsibility": {
          "type": "string",
          "description": "Specific responsibility"
        },
        "raci": {
          "type": "string",
          "enum": ["R", "A", "C", "I"],
          "description": "RACI designation"
        },
        "involvementFrequency": {
          "type": "string",
          "enum": ["continuous", "daily", "weekly", "monthly", "as-needed"],
          "description": "How often involved"
        }
      }
    },
    "dataSource": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Data source name"
        },
        "type": {
          "type": "string",
          "enum": ["form", "file", "api", "database", "manual-entry", "system-generated"],
          "description": "Data source type"
        },
        "frequency": {
          "type": "string",
          "description": "How often data is received"
        },
        "format": {
          "type": "string",
          "description": "Data format"
        },
        "qualityRequirements": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Data quality requirements"
        }
      }
    },
    "dataOutput": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Data output name"
        },
        "type": {
          "type": "string",
          "enum": ["report", "file", "api-response", "database-update", "notification", "transaction"],
          "description": "Output type"
        },
        "destination": {
          "type": "string",
          "description": "Output destination"
        },
        "format": {
          "type": "string",
          "description": "Output format"
        },
        "frequency": {
          "type": "string",
          "description": "How often generated"
        }
      }
    },
    "validationRules": {
      "type": "object",
      "properties": {
        "requiredFields": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Fields that must be completed"
        },
        "businessRules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule": {
                "type": "string",
                "description": "Business rule description"
              },
              "validation": {
                "type": "string",
                "description": "Validation logic"
              }
            }
          }
        },
        "qualityThresholds": {
          "type": "object",
          "properties": {
            "minimumCompleteness": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Minimum percentage of fields that must be completed"
            },
            "requiredDocumentation": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Required documentation types"
            }
          }
        }
      }
    }
  }
}