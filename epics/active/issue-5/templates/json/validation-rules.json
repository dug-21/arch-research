{
  "validationRules": {
    "processValidation": {
      "requiredFields": {
        "critical": [
          "processId",
          "processName", 
          "description",
          "category",
          "status",
          "owner"
        ],
        "important": [
          "frequency",
          "businessPriority",
          "systemsInvolved",
          "stakeholders"
        ],
        "recommended": [
          "successRate",
          "slaRequirements",
          "riskAssessment",
          "improvementOpportunities"
        ]
      },
      "fieldValidation": {
        "processId": {
          "pattern": "^[A-Z]{2,5}-\\d{3,6}$",
          "description": "Must follow format: PREFIX-NUMBER (e.g., PROC-001, PAY-12345)",
          "uniqueness": "global"
        },
        "processName": {
          "minLength": 5,
          "maxLength": 100,
          "pattern": "^[A-Z][A-Za-z0-9\\s\\-_]+$",
          "description": "Must start with capital letter, contain only alphanumeric, spaces, hyphens, underscores"
        },
        "description": {
          "minLength": 20,
          "maxLength": 1000,
          "qualityCheck": "Must explain process purpose, scope, and key outcomes"
        },
        "category": {
          "validValues": ["TRANS", "COMP", "CUST", "INTERNAL", "INTEGRATION"],
          "description": "Must be from predefined category list"
        },
        "status": {
          "validValues": ["active", "deprecated", "planned", "suspended", "retired"],
          "businessRule": "Only 'active' processes should have performance metrics"
        },
        "frequency": {
          "validValues": ["continuous", "real-time", "hourly", "daily", "weekly", "monthly", "quarterly", "annually", "ad-hoc", "event-driven"]
        },
        "businessPriority": {
          "validValues": ["critical", "high", "medium", "low"],
          "businessRule": "Critical processes must have SLA requirements"
        },
        "automationLevel": {
          "validValues": ["manual", "semi-automated", "fully-automated", "ai-enhanced"]
        },
        "riskLevel": {
          "validValues": ["very-low", "low", "medium", "high", "very-high"],
          "businessRule": "High/very-high risk processes must have mitigation plans"
        }
      },
      "businessRules": {
        "processHierarchy": {
          "rule": "Sub-processes must have valid parent process",
          "validation": "parentProcess must exist in process inventory",
          "severity": "error"
        },
        "systemDependencies": {
          "rule": "Referenced systems must exist in system inventory",
          "validation": "All systemIds in systemsInvolved must be valid",
          "severity": "error"
        },
        "stakeholderReferences": {
          "rule": "Referenced stakeholders must exist in stakeholder directory",
          "validation": "All stakeholderIds must be valid",
          "severity": "warning"
        },
        "slaConsistency": {
          "rule": "Critical processes must have SLA requirements",
          "validation": "businessPriority = 'critical' implies slaRequirements is not empty",
          "severity": "warning"
        },
        "automationAlignment": {
          "rule": "Automation level should align with volume and complexity",
          "validation": "High volume + low complexity should consider automation",
          "severity": "info"
        },
        "improvementOpportunities": {
          "rule": "Processes with pain points should have improvement opportunities",
          "validation": "Processes with quality issues should have improvement plans",
          "severity": "info"
        }
      }
    },
    "dataQuality": {
      "completenessRules": {
        "minimumCompletion": {
          "critical": 100,
          "important": 80,
          "recommended": 60
        },
        "categorySpecificRules": {
          "TRANS": {
            "requiredAdditional": ["volume", "successRate", "slaRequirements"],
            "description": "Transaction processes need volume and performance data"
          },
          "COMP": {
            "requiredAdditional": ["complianceRequirements", "riskAssessment"],
            "description": "Compliance processes need risk and regulatory data"
          },
          "CUST": {
            "requiredAdditional": ["customerImpact", "qualityMetrics"],
            "description": "Customer processes need impact and quality metrics"
          }
        }
      },
      "consistencyRules": {
        "crossFieldValidation": [
          {
            "rule": "High frequency processes should have performance metrics",
            "condition": "frequency in ['continuous', 'real-time', 'hourly']",
            "requirement": "qualityMetrics.successRate must be defined",
            "severity": "warning"
          },
          {
            "rule": "Customer-facing processes should have customer impact rating",
            "condition": "category = 'CUST'",
            "requirement": "businessContext.customerImpact must be defined",
            "severity": "error"
          },
          {
            "rule": "High-risk processes need detailed risk assessment",
            "condition": "riskAssessment.riskLevel in ['high', 'very-high']",
            "requirement": "riskAssessment.riskFactors must have >= 3 items",
            "severity": "warning"
          }
        ]
      }
    },
    "performanceValidation": {
      "metricRules": {
        "successRateValidation": {
          "minimum": 0,
          "maximum": 100,
          "businessRule": "Target should be higher than current for improvement processes"
        },
        "volumeValidation": {
          "consistency": "peak volume should be >= average volume",
          "businessRule": "Volume units must be appropriate for frequency"
        },
        "durationValidation": {
          "consistency": "maximum duration should be >= average >= minimum",
          "businessRule": "Duration should align with frequency and SLA"
        }
      },
      "benchmarkRules": {
        "industryBenchmarks": {
          "cardAuthorization": {
            "successRate": { "min": 85, "target": 95 },
            "responseTime": { "max": 3000, "target": 1000, "unit": "ms" }
          },
          "customerOnboarding": {
            "successRate": { "min": 90, "target": 98 },
            "processingTime": { "max": 120, "target": 30, "unit": "minutes" }
          },
          "reconciliation": {
            "matchRate": { "min": 95, "target": 99 },
            "exceptionRate": { "max": 5, "target": 1, "unit": "percentage" }
          }
        }
      }
    },
    "complianceValidation": {
      "regulatoryRules": {
        "pciCompliance": {
          "applicableProcesses": "Processes handling payment card data",
          "condition": "dataFlow contains card data or payment processing",
          "requirements": [
            "securityRequirements.classification = 'highly-confidential'",
            "securityRequirements.complianceRequirements contains 'PCI DSS'",
            "Encryption and tokenization controls documented"
          ]
        },
        "kycAmlCompliance": {
          "applicableProcesses": "Customer identification and transaction monitoring",
          "condition": "category = 'COMP-KYC' or process involves customer identification",
          "requirements": [
            "complianceRequirements contains 'KYC' or 'AML'",
            "businessRules include identity verification",
            "Sanctions screening documented"
          ]
        },
        "gdprCompliance": {
          "applicableProcesses": "Processes handling EU personal data",
          "condition": "geographicScope contains EU countries and handles personal data",
          "requirements": [
            "dataFlow.inputs include privacy consent",
            "securityRequirements.complianceRequirements contains 'GDPR'",
            "Data retention and deletion procedures documented"
          ]
        }
      },
      "auditRules": {
        "auditTrailRequirements": {
          "highRiskProcesses": {
            "condition": "riskLevel in ['high', 'very-high'] or businessPriority = 'critical'",
            "requirements": [
              "Audit trail required = true",
              "Change control process documented",
              "Regular audit schedule defined"
            ]
          }
        },
        "segregationOfDuties": {
          "condition": "Financial or high-value processes",
          "requirements": [
            "Multiple approval levels defined",
            "Maker-checker controls implemented",
            "No single person can complete end-to-end process alone"
          ]
        }
      }
    },
    "qualityScoring": {
      "scoringCriteria": {
        "completeness": {
          "weight": 30,
          "calculation": "percentage of required fields completed",
          "thresholds": {
            "excellent": 95,
            "good": 85,
            "fair": 70,
            "poor": 50
          }
        },
        "accuracy": {
          "weight": 25,
          "calculation": "validation rules passed / total validation rules",
          "factors": [
            "Field format compliance",
            "Business rule adherence", 
            "Cross-reference validity"
          ]
        },
        "consistency": {
          "weight": 20,
          "calculation": "internal consistency checks passed",
          "factors": [
            "Metric alignment",
            "Role-responsibility mapping",
            "Process flow logic"
          ]
        },
        "richness": {
          "weight": 15,
          "calculation": "optional fields and detailed descriptions",
          "factors": [
            "Improvement opportunities identified",
            "Detailed business rules",
            "Comprehensive stakeholder mapping"
          ]
        },
        "currentness": {
          "weight": 10,
          "calculation": "recency of updates and review cycles",
          "thresholds": {
            "current": "< 3 months",
            "acceptable": "< 6 months", 
            "stale": "< 12 months",
            "outdated": "> 12 months"
          }
        }
      },
      "overallQualityRating": {
        "calculation": "weighted sum of all criteria",
        "ratings": {
          "A": { "min": 90, "description": "Excellent - Comprehensive and current" },
          "B": { "min": 80, "description": "Good - Well documented with minor gaps" },
          "C": { "min": 70, "description": "Fair - Adequate documentation, needs improvement" },
          "D": { "min": 60, "description": "Poor - Significant gaps, requires attention" },
          "F": { "min": 0, "description": "Failing - Inadequate documentation" }
        }
      }
    },
    "validationExecution": {
      "validationSequence": [
        {
          "step": 1,
          "name": "Schema Validation",
          "description": "Validate against JSON schema structure"
        },
        {
          "step": 2,
          "name": "Required Field Check",
          "description": "Ensure all critical and important fields are present"
        },
        {
          "step": 3,
          "name": "Format Validation",
          "description": "Check field formats and data types"
        },
        {
          "step": 4,
          "name": "Business Rule Validation",
          "description": "Apply business logic validation rules"
        },
        {
          "step": 5,
          "name": "Cross-Reference Validation",
          "description": "Validate references to other entities"
        },
        {
          "step": 6,
          "name": "Consistency Checks",
          "description": "Check internal consistency and alignment"
        },
        {
          "step": 7,
          "name": "Quality Scoring",
          "description": "Calculate overall quality score"
        },
        {
          "step": 8,
          "name": "Compliance Verification",
          "description": "Check regulatory and audit requirements"
        }
      ],
      "errorHandling": {
        "critical": "Stop processing, require fixes",
        "warning": "Continue processing, flag for review",
        "info": "Continue processing, note for improvement"
      },
      "reportFormat": {
        "summary": {
          "totalValidations": "number",
          "passed": "number",
          "warnings": "number",
          "errors": "number",
          "qualityScore": "number",
          "qualityRating": "string"
        },
        "details": {
          "byCategory": "validation results grouped by category",
          "byProcess": "validation results per process",
          "byRule": "validation results per rule"
        },
        "recommendations": {
          "immediate": "Critical issues requiring immediate attention",
          "planned": "Improvements to plan for next review cycle",
          "optional": "Nice-to-have enhancements"
        }
      }
    }
  }
}