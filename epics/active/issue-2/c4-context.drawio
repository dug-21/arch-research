        <!-- Software System (Main) -->
        <mxCell id="system" value="&lt;b&gt;E-Commerce Platform&lt;/b&gt;&lt;br&gt;[Software System]&lt;br&gt;&lt;br&gt;Allows customers to browse and purchase products, manage orders, and handle payments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1168BD;strokeColor=#06426C;fontColor=#FFFFFF;fontSize=14;align=center;verticalAlign=middle;" vertex="1" parent="1">
