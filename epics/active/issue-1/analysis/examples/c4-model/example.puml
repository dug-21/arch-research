@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

!define DEVICONS https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/master/devicons
!define FONTAWESOME https://raw.githubusercontent.com/tupadr3/plantuml-icon-font-sprites/master/font-awesome-5

!include DEVICONS/angular.puml
!include DEVICONS/java.puml
!include DEVICONS/postgresql.puml
!include FONTAWESOME/users.puml

LAYOUT_WITH_LEGEND()

title E-Commerce Platform - Container Diagram

Person(customer, "Customer", "A customer purchasing products", $sprite="users")

System_Boundary(ecommerce, "E-Commerce System") {
    Container(web_app, "Web Application", "Angular", "Provides e-commerce functionality to customers via their web browser", $sprite="angular")
    Container(api_app, "API Application", "Java, Spring Boot", "Provides e-commerce functionality via JSON/REST API", $sprite="java")
    Container(database, "Database", "PostgreSQL", "Stores user registration information, product catalog, orders, etc.", $sprite="postgresql")
    Container(payment, "Payment Gateway", "External Service", "Handles credit card processing")
}

System_Ext(email_system, "Email System", "SendGrid")
System_Ext(shipping_system, "Shipping System", "FedEx/UPS API")

Rel(customer, web_app, "Uses", "HTTPS")
Rel(web_app, api_app, "Makes API calls to", "JSON/REST")
Rel(api_app, database, "Reads from and writes to", "JDBC")
Rel(api_app, payment, "Processes payments using", "REST API")
Rel(api_app, email_system, "Sends emails using", "SMTP")
Rel(api_app, shipping_system, "Ships products using", "REST API")

@enduml