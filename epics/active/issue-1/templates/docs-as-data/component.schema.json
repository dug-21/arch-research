{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://architecture.example.com/schemas/component.schema.json",
  "title": "Component Documentation Schema",
  "description": "Schema for documenting system components in a structured format",
  "type": "object",
  "required": [
    "id",
    "name",
    "type",
    "description",
    "owner",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier for the component"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the component"
    },
    "type": {
      "type": "string",
      "enum": [
        "service",
        "library",
        "database",
        "queue",
        "cache",
        "frontend",
        "api-gateway",
        "external"
      ],
      "description": "Type of component"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the component's purpose and functionality"
    },
    "owner": {
      "type": "object",
      "required": ["team", "contact"],
      "properties": {
        "team": {
          "type": "string",
          "description": "Team responsible for the component"
        },
        "contact": {
          "type": "string",
          "format": "email",
          "description": "Contact email for the team"
        },
        "slack": {
          "type": "string",
          "description": "Slack channel for the team"
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Current version of the component"
    },
    "repository": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Git repository URL"
        },
        "path": {
          "type": "string",
          "description": "Path within monorepo if applicable"
        }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["rest", "graphql", "grpc", "websocket", "event"]
        },
        "specification": {
          "type": "string",
          "description": "Path or URL to API specification"
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "method": {"type": "string"},
              "path": {"type": "string"},
              "description": {"type": "string"},
              "authentication": {"type": "boolean"}
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "internal": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "version": {"type": "string"},
              "type": {
                "type": "string",
                "enum": ["sync", "async", "compile-time"]
              },
              "critical": {"type": "boolean"}
            }
          }
        },
        "external": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {"type": "string"},
              "version": {"type": "string"},
              "license": {"type": "string"},
              "purpose": {"type": "string"}
            }
          }
        }
      }
    },
    "infrastructure": {
      "type": "object",
      "properties": {
        "runtime": {
          "type": "string",
          "description": "Runtime environment (e.g., node:18, python:3.11)"
        },
        "resources": {
          "type": "object",
          "properties": {
            "cpu": {"type": "string"},
            "memory": {"type": "string"},
            "storage": {"type": "string"}
          }
        },
        "scaling": {
          "type": "object",
          "properties": {
            "min": {"type": "integer"},
            "max": {"type": "integer"},
            "metric": {"type": "string"}
          }
        }
      }
    },
    "quality": {
      "type": "object",
      "properties": {
        "sla": {
          "type": "object",
          "properties": {
            "availability": {"type": "string"},
            "latency": {
              "type": "object",
              "properties": {
                "p50": {"type": "string"},
                "p95": {"type": "string"},
                "p99": {"type": "string"}
              }
            }
          }
        },
        "testing": {
          "type": "object",
          "properties": {
            "unit": {"type": "number", "minimum": 0, "maximum": 100},
            "integration": {"type": "number", "minimum": 0, "maximum": 100},
            "e2e": {"type": "number", "minimum": 0, "maximum": 100}
          }
        }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "classification": {
          "type": "string",
          "enum": ["public", "internal", "confidential", "restricted"]
        },
        "authentication": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["oauth2", "jwt", "api-key", "mtls", "basic"]
          }
        },
        "compliance": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Tags for categorization and search"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created": {"type": "string", "format": "date-time"},
        "updated": {"type": "string", "format": "date-time"},
        "deprecated": {"type": "boolean"},
        "sunset": {"type": "string", "format": "date"}
      }
    }
  }
}
